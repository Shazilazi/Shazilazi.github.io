# Tells Ruby where to download gems from.
# rubygems.org is the official public registry —
# almost every Ruby project uses this same line.
source "https://rubygems.org"

# The Jekyll gem itself — the engine that builds your site.
# "~> 4.3" means "version 4.3 or higher, but not 5.0 or above".
# The ~> operator is called the pessimistic constraint — it allows
# minor updates (4.4, 4.5) but blocks breaking major version changes.
gem "jekyll", "~> 4.3"

# The SEO plugin used in your default layout via the {% seo %} tag.
# Automatically generates meta tags for search engines and social sharing
# (page title, description, Open Graph for LinkedIn previews etc).
# No version pinned here — always installs the latest compatible version.
gem "jekyll-seo-tag"
